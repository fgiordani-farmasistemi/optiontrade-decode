# Copia questo file in `.env` e configura il provider LLM che vuoi usare.
# La sintesi/traduzione e' fatta da un modello esterno: puoi usare OpenAI
# (chiave da https://platform.openai.com/) oppure Anthropic
# (chiave da https://console.anthropic.com/).
#
# Senza alcuna chiave, l'app funziona solo in lettura: ricerca e schede
# video restano utilizzabili, ma l'ingest di nuovi video sara' disabilitato.

# --- Scelta provider --------------------------------------------------
# Valori ammessi: openai | anthropic
LLM_PROVIDER=openai

# --- OpenAI -----------------------------------------------------------
OPENAI_API_KEY=
# Modelli mini consigliati: gpt-5.4-mini (piu' recente), gpt-5-mini (rodato).
# Nota: gpt-5.1 NON ha variante mini.
OPENAI_MODEL=gpt-5.4-mini

# --- Anthropic --------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Whisper fallback -------------------------------------------------
# Quando un video YouTube non ha sottotitoli automatici, l'app puo'
# scaricare l'audio e trascriverlo via OpenAI Whisper (richiede una
# chiave OPENAI_API_KEY valida anche se il provider LLM e' anthropic).
# Costo indicativo: ~6 centesimi ogni 10 minuti di video.
# Imposta 1 per abilitare, 0 per disabilitare (i video senza sub falliscono).
ENABLE_WHISPER_FALLBACK=1
WHISPER_MODEL=whisper-1

# --- Webapp -----------------------------------------------------------
# Porta su cui gira la webapp locale (default 5000)
PORT=5000
